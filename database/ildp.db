            SELECT 
              e.Employee_ID,
              e.First_Name,
              e.Middle_Initial,
              e.Last_Name,
              e.Office,
              e.Position,
              el.Learning_Needs,
              el.Basis_Learning,
              el.Proposed_Action,
              el.Target_Schedule
            FROM Employee e
            JOIN Employee_LearningNeeds el ON e.Employee_ID = el.Employee_IDƒ[ 99†QtableEmployee_LearningNeedsEmployee_LearningNeedsCREATE TABLE Employee_LearningNeeds (
